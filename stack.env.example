# Скопируйте в .env рядом с docker-compose.stack.yml на сервере и подставьте значения.
# Образы: теги из GHCR после сборки на main (sha-... или latest).

NETWORK_BACKEND_IMAGE=ghcr.io/your-org/network/backend:latest
NETWORK_FRONTEND_IMAGE=ghcr.io/your-org/network/frontend:latest

SECRET_KEY=
POSTGRES_PASSWORD=
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=http://localhost:9000
FRONTEND_URL=http://localhost:9000

# Опционально: DATABASE_URL=postgres://... (иначе POSTGRES_* ниже в compose)
DJANGO_SETTINGS_MODULE=config.settings.production

# Порты на хосте
# API_PORT=8000
# WEB_PORT=80
