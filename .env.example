# Скопируйте в .env и при необходимости измените
SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,api

POSTGRES_DB=network
POSTGRES_USER=network
POSTGRES_PASSWORD=network

# Для API в Docker POSTGRES_HOST задаётся в compose (db).
# Локальный manage.py без Docker: POSTGRES_HOST=localhost

REDIS_HOST=localhost
REDIS_PORT=6379

EMAIL_HOST=localhost
EMAIL_PORT=1025

CORS_ALLOWED_ORIGINS=http://localhost:9000,http://127.0.0.1:9000

# Ссылка в письмах сброса пароля (клиент)
FRONTEND_URL=http://localhost:9000
